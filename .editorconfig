# editorconfig: consistent formatting across editors and ides
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.py]
indent_size = 4
max_line_length = 88

[*.{yml,yaml}]
indent_size = 2

[*.{json,toml}]
indent_size = 2

[*.{md,rst,txt}]
indent_size = 2
trim_trailing_whitespace = false

[*.tex]
indent_size = 2
trim_trailing_whitespace = false

[*.{sh,bash,zsh}]
indent_size = 2

[Makefile]
indent_style = tab
indent_size = 4

[*.{cfg,ini}]
indent_size = 4
