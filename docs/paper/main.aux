\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces Ablation curves. Left: \textsc  {SAD}{} threshold $k$ controls the TPR/FPR tradeoff; $k=2.0$ (vertical dashed) achieves $\text  {TPR}\!\approx \!1.00$ for \textsc  {MINJA}{}, $\text  {TPR}\!\approx \!0.20$ for \textsc  {InjecMEM}{}, and $\text  {TPR}\!\approx \!0.00$ for \textsc  {AgentPoison}{} (centroid passage falls within benign similarity distribution at un-triggered calibration). $\text  {FPR}\!\approx \!0.05$ across all attacks. Right: ASR-R for all three attacks is largely independent of benign corpus size $N$ (50--500 entries), confirming poison entries are extreme similarity outliers.}}{16}{figure.caption.51}\protected@file@percent }
\newlabel{fig:ablation_combined}{{10}{16}{Ablation curves. Left: \sad {} threshold $k$ controls the TPR/FPR tradeoff; $k=2.0$ (vertical dashed) achieves $\tpr \!\approx \!1.00$ for \minja {}, $\tpr \!\approx \!0.20$ for \injecmem {}, and $\tpr \!\approx \!0.00$ for \agentpoison {} (centroid passage falls within benign similarity distribution at un-triggered calibration). $\fpr \!\approx \!0.05$ across all attacks. Right: ASR-R for all three attacks is largely independent of benign corpus size $N$ (50--500 entries), confirming poison entries are extreme similarity outliers}{figure.caption.51}{}}
