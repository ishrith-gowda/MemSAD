\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces SAD threshold sweep: TPR vs.\ FPR as the detection parameter $k$ ranges from $0.5$ to $4.0$. \textsc  {MINJA}{} (plain calibration) traces a near-ideal left-edge curve. \textsc  {AgentPoison}{} (plain calibration) is undetectable at all thresholds (flat line at TPR$=0$), while triggered-query calibration recovers perfect detection (TPR$=1$, FPR$=0$ at $k=2.0$, marked with $\star $). \textsc  {InjecMEM}{} achieves moderate detection (broad anchors are less anomalous). Figure generated from the measured threshold sweep in Table~\ref {tab:ablation}.}}{12}{figure.caption.31}\protected@file@percent }
\newlabel{fig:sad_roc}{{4}{12}{SAD threshold sweep: TPR vs.\ FPR as the detection parameter $k$ ranges from $0.5$ to $4.0$. \minja {} (plain calibration) traces a near-ideal left-edge curve. \agentpoison {} (plain calibration) is undetectable at all thresholds (flat line at TPR$=0$), while triggered-query calibration recovers perfect detection (TPR$=1$, FPR$=0$ at $k=2.0$, marked with $\star $). \injecmem {} achieves moderate detection (broad anchors are less anomalous). Figure generated from the measured threshold sweep in Table~\ref {tab:ablation}}{figure.caption.31}{}}
